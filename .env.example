# Server
PORT=3000

# Database
DB_PATH=./data/receipts.db

# Ollama (local LLM — used when RECEIPT_PARSER_MODE=local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Auth
# Generate a strong random secret for production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-before-deploying

# Receipt parsing mode
# "local"  — use Ollama (default, no API key required)
# "claude" — use Anthropic Claude API (requires ANTHROPIC_API_KEY)
RECEIPT_PARSER_MODE=local

# Anthropic Claude API (required only when RECEIPT_PARSER_MODE=claude)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model to use for receipt parsing (RECEIPT_PARSER_MODE=claude only)
CLAUDE_MODEL=claude-sonnet-4-20250514
